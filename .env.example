# Copy to .env and fill in values

# Host path to ./data — required so Prowler/TruffleHog containers can write scan output.
# Set to the absolute path on your machine, e.g. /home/ubuntu/rhino-scan/data
HOST_DATA_DIR=

# ── RhinoScan native baseline checks ──────────────────────────────────────────
# RhinoScan reads AWS profiles from your ~/.aws/config — no role ARN is pasted in.
# Host directory mounted read-only into the backend at /root/.aws. Defaults to
# $HOME/.aws; override to point at a client-specific config directory.
AWS_CONFIG_DIR=
# Profiles never offered for scanning (comma-separated).
AWS_EXCLUDED_PROFILES=default,grsconsultant
# Regional checks (GuardDuty, Security Hub, EC2, Lambda) default to this region.
AWS_DEFAULT_REGION=us-west-2

# Optional static credentials — only the legacy Prowler/TruffleHog path uses these.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# ── GitHub auth ───────────────────────────────────────────────────────────────
# GitHub-side scans (Prowler GitHub provider, TruffleHog secrets, OpenSSF
# Scorecard) authenticate with your gh login. The backend resolves a PAT from,
# in order: GH_TOKEN, GITHUB_TOKEN, then ~/.config/gh/hosts.yml (mounted into
# the container — see docker-compose.yml). Set one of these only if you are NOT
# logged in via `gh auth login`.
GH_TOKEN=
GITHUB_TOKEN=

# GitHub App (legacy OAuth installation flow — optional, not used by gh-login path)
GITHUB_APP_ID=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Paths (container-internal — leave as-is for Docker Compose)
DATA_DIR=/data
DATABASE_URL=sqlite:////data/db/rhino.db

# Docker images
PROWLER_IMAGE=toniblyx/prowler:latest
TRUFFLE_IMAGE=trufflesecurity/trufflehog:latest
SCORECARD_IMAGE=gcr.io/openssf/scorecard:stable
