# Copy to .env and fill in values

# Host path to ./data — required so Prowler/TruffleHog containers can write scan output.
# Set to the absolute path on your machine, e.g. /home/ubuntu/rhino-scan/data
HOST_DATA_DIR=

# AWS credentials for Prowler role assumption and IAM correlation (uses default chain if unset)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_DEFAULT_REGION=us-east-1

# GitHub App (for TruffleHog OAuth flow — optional for V1, use token directly in UI)
GITHUB_APP_ID=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Paths (container-internal — leave as-is for Docker Compose)
DATA_DIR=/data
DATABASE_URL=sqlite:////data/db/rhino.db

# Docker images
PROWLER_IMAGE=toniblyx/prowler:latest
TRUFFLE_IMAGE=trufflesecurity/trufflehog:latest
